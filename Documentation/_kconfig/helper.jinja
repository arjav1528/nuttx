{# Shared macros for Kconfig RST generation #}
{% macro help(sc) %}
{{ render_help(sc) }}
{% endmacro %}

{% macro direct_dep(sc) %}
{% if has_non_trivial_dep(sc) %}
**Direct dependency:** ``{{ expr_str(sc.direct_dep) }}``
{% endif %}
{% endmacro %}

{% macro defaults(sc) %}
{% if sc.defaults %}
**Defaults:**
{% for expr, value in sc.defaults %}
{%- set expr_text = expr_str(expr) -%}
- ``{{ expr_text if expr_text else '""' }}`` → ``{{ format_default_value(value) }}``
{% endfor %}
{% endif %}
{% endmacro %}

{% macro kconfig_definition(sc) %}
{{ render_kconfig_definition(sc) }}
{% endmacro %}
